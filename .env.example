# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is the committed template.
# test check
# Database
POSTGRES_USER=
POSTGRES_PASSWORD=     # generate: openssl rand -base64 24
POSTGRES_DB=

# JWT
JWT_KEY=               # generate: openssl rand -base64 32
JWT_ISSUER=TaskAppServer
JWT_AUDIENCE=TaskAppClient
JWT_EXPIRY_MINUTES=60

# Email (Resend SMTP)
Email__Host=smtp.resend.com
Email__Port=465
Email__Security=SslOnConnect
Email__Username=resend
Email__Password=       # Resend API key — starts with re_
Email__FromAddress=
Email__FromName=

# Frontend
Frontend__BaseURL=
